{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "types": ["astro/client", "node"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@convex/*": ["./convex/*"]
    },
  }
}